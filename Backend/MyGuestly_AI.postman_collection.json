    {
      "name": "👥 Guests & Invitations",
      "item": [
        {
          "name": "Invite Single Guest",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.guest && res.data.guest.id) {",
                  "  pm.collectionVariables.set('GUEST_ID', res.data.guest.id);",
                  "  console.log(' GUEST_ID set:', res.data.guest.id);",
                  "}",
                  "if (res.data && res.data.invitation && res.data.invitation.token) {",
                  "  pm.collectionVariables.set('INVITATION_TOKEN', res.data.invitation.token);",
                  "  console.log(' INVITATION_TOKEN set:', res.data.invitation.token);",
                  "}",
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has invitation token', () => pm.expect(res.data.invitation.token).to.be.a('string'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ACCESS_TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Grace Hopper\",\n  \"email\": \"grace@example.com\",\n  \"phone\": \"08012345678\"\n}"
            },
            "url": {
