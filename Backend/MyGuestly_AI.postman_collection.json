              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('Check-in successful or already used', () => {",
                  "  pm.expect([200, 400]).to.include(pm.response.code);",
                  "});",
                  "console.log('QR verification result:', res.message);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"totp\": \"482917\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/verify-gate/{{INVITATION_TOKEN}}",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "verify-gate",
                "{{INVITATION_TOKEN}}"
              ]
            },
            "description": "Replace the totp value with the current 6-digit code generated from the guest's invitation token. The code rotates every 30 seconds."
          }
        }
      ]
