generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(uuid())
  fullName      String?
  email         String         @unique
  phone         String?        @unique
  password      String
  role          Role           @default(HOST)
  isVerified    Boolean        @default(false)
  avatarUrl     String?
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  comments      Comment[]
  events        Event[]
  invitations   Invitation[]
  likes         Like[]
  mediaUploads  Media[]
  memories      Memory[]
  notifications Notification[]

  @@index([email])
  @@index([deletedAt])
}

model Event {
  id            String         @id @default(uuid())
  title         String
  description   String?
  eventCategory String?
  venueName     String?
  address       String?
  location      String?
  coverUrl      String?
  themeAccent   String?
  rsvpDeadline  DateTime?
  startDate     DateTime
  endDate       DateTime
  eventCode     String         @unique
  status        String         @default("DRAFT")
  maxGuests     Int            @default(0)
  publishedAt   DateTime?
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  hostId        String
  checkIns      CheckIn[]
  host          User           @relation(fields: [hostId], references: [id], onDelete: Cascade)
  guests        Guest[]
  invitations   Invitation[]
  media         Media[]
  memories      Memory[]
  notifications Notification[]
  qrCodes       QRCode[]

  @@index([hostId])
  @@index([startDate])
  @@index([updatedAt])
}

model Guest {
  id         String      @id @default(uuid())
  fullName   String
  email      String?
  phone      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  eventId    String
  checkIn    CheckIn?
  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invitation Invitation?

  @@unique([eventId, email])
  @@unique([eventId, phone])
  @@index([eventId])
}

model Invitation {
  id        String           @id @default(uuid())
  status    InvitationStatus @default(PENDING)
  token     String           @unique @default(uuid())
  sentAt    DateTime?
  sentBy    String?
  rsvpAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  eventId   String
  guestId   String           @unique
  userId    String?
  event     Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guest     Guest            @relation(fields: [guestId], references: [id], onDelete: Cascade)
  user      User?            @relation(fields: [userId], references: [id])
  qrCode    QRCode?

  @@index([eventId])
  @@index([token])
}

model QRCode {
  id           String     @id @default(uuid())
  code         String     @unique
  isScanned    Boolean    @default(false)
  scannedAt    DateTime?
  scannedByIp  String?
  createdAt    DateTime   @default(now())
  invitationId String     @unique
  eventId      String
  event        Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([eventId])
}

model CheckIn {
  id          String   @id @default(uuid())
  checkedAt   DateTime @default(now())
  checkedByIp String?
  eventId     String
  guestId     String   @unique
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guest       Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model Media {
  id              String             @id @default(uuid())
  url             String
  publicId        String
  mediaType       MediaType
  size            Int?
  width           Int?
  height          Int?
  duration        Float?
  voiceNoteUrl    String?
  metadata        Json?
  aiStatus        AIProcessingStatus @default(PENDING)
  rejectionReason String?
  pHash           String?
  capturedAt      DateTime?
  clutchName      String?
  createdAt       DateTime           @default(now())
  eventId         String
  uploaderId      String
  comments        Comment[]
  guestFaces      GuestFace[]
  likes           Like[]
  event           Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  uploader        User               @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
  tags            MediaTag[]

  @@index([eventId])
  @@index([uploaderId])
  @@index([eventId, pHash])
  @@index([eventId, clutchName])
}

model MediaTag {
  id         String @id @default(uuid())
  label      String
  confidence Float?
  mediaId    String
  media      Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([mediaId, label])
  @@index([mediaId])
}

model Memory {
  id        String     @id @default(uuid())
  type      MemoryType
  content   String?
  audioUrl  String?
  createdAt DateTime   @default(now())
  eventId   String
  authorId  String
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  mediaId   String
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([mediaId])
}

model Like {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  mediaId   String
  userId    String
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mediaId, userId])
  @@index([mediaId])
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  userId    String
  eventId   String?
  event     Event?           @relation(fields: [eventId], references: [id])
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([eventId])
}

model GuestFace {
  id          String @id @default(uuid())
  guestId     String
  boundingBox Json?
  mediaId     String
  media       Media  @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@index([guestId])
}

enum Role {
  SUPER_ADMIN
  HOST
  PHOTOGRAPHER
  GUEST
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  CHECKED_IN
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
}

enum MemoryType {
  TEXT
  VOICE
}

enum NotificationType {
  INVITATION_SENT
  RSVP_RECEIVED
  EVENT_UPDATED
  EVENT_REMINDER
  MEDIA_UPLOADED
  QR_SCANNED
}

enum AIProcessingStatus {
  PENDING
  APPROVED
  REJECTED
}
