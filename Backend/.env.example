PORT=5000
NODE_ENV=development
DATABASE_URL="postgresql://postgres:supersecurepassword@localhost:5432/myguestly_db?schema=public"

# JWT / Auth
JWT_SECRET="your_jwt_secret"
JWT_REFRESH_SECRET="your_jwt_refresh_secret"
JWT_EXPIRES_IN="3d"

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Email (SMTP)
EMAIL_SERVICE_HOST="smtp.example.com"
EMAIL_SERVICE_PORT="587"
EMAIL_SERVICE_USER="user@example.com"
EMAIL_SERVICE_PASS=""

# Local dev helper: set to true to allow seed script to use temporary dev secrets
# (ONLY use in local dev, never in CI or production)
ALLOW_DEV_SEED=false