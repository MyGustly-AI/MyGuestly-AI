PORT=5000
NODE_ENV=development

DATABASE_URL="postgresql://postgres:dbpassword@localhost:5432/myguestly_db?schema=public"

# JWT / AUTH
JWT_SECRET="your_jwt_secret"
JWT_REFRESH_SECRET="your_jwt_refresh_secret"
JWT_EXPIRES_IN="17d"

# CLOUDINARY (optional)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""


QR_SECRET=""

# EMAIL (RECOMMENDED: RESEND)
RESEND_API_KEY="re_your_resend_key"
EMAIL_FROM="MyGuestly <noreply@yourdomain.com>"

# REDIS (BullMQ)
REDIS_URL="redis://127.0.0.1:6379"

# SMTP (LEGACY - optional fallback only)
EMAIL_SERVICE_HOST="smtp.example.com"
EMAIL_SERVICE_PORT=587
EMAIL_SERVICE_USER="user@example.com"
EMAIL_SERVICE_PASS=""

# GOOGLE OAUTH
GOOGLE_CLIENT_ID="your_google_client_id"

# DEV TOOLS
ALLOW_DEV_SEED=false